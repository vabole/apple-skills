{
  "name": "apple-skills",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "refresh-docs": "tsx scripts/apple-docs.ts refresh",
    "fetch-doc": "tsx scripts/apple-docs.ts fetch",
    "typecheck": "tsgo --project tsconfig.json --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "lint": "biome check . --error-on-warnings",
    "format": "biome check . --write",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@types/node": "^24.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20250408.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
